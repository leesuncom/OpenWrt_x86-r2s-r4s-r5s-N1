# ===== 系统核心设置 =====
CONFIG_GRUB_TIMEOUT="0"          # 无启动延迟
CONFIG_GRUB_CONSOLE=n            # 禁用GRUB控制台
CONFIG_TARGET_ROOTFS_EXT4FS=n    # 禁用EXT4（不适合闪存）
CONFIG_TARGET_ROOTFS_CPIOGZ=n    # 禁用CPIOGZ
CONFIG_TARGET_ROOTFS_SQUASHFS=y  # 启用SquashFS（必须）
# CONFIG_TARGET_ROOTFS_JFFS2=y     # 启用JFFS2（必须）

# 固件分区大小 (使用默认值，自动分配空间)
# CONFIG_TARGET_ROOTFS_PARTSIZE=  # 注释掉，使用自动分配

# ===== 安全与验证 =====
CONFIG_SIGNED_PACKAGES=n         # 不要求签名包
CONFIG_SIGNATURE_CHECK=n         # 禁用签名检查

# ===== 编译优化 =====
CONFIG_LUCI_CSSTIDY=n            # 禁用CSS优化
CONFIG_CCACHE=y                  # 启用编译缓存
CONFIG_BUILD_PATENTED=y          # 包含专利算法
CONFIG_IB=y                      # 镜像生成器
CONFIG_IB_STANDALONE=y
CONFIG_JSON_OVERVIEW_IMAGE_INFO=y

# ===== 网络基础 =====
CONFIG_IPV6=y                    # IPv6支持
CONFIG_PACKAGE_dnsmasq-full=y    # 完整DNS/DHCP服务
CONFIG_PACKAGE_dnsmasq_full_dhcp=y
CONFIG_PACKAGE_dnsmasq_full_ipset=y
CONFIG_PACKAGE_firewall=y        # 防火墙（改为必需）
CONFIG_PACKAGE_miniupnpd-iptables=m # UPnP支持

# ===== Web管理界面 =====
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-ssl=y        # HTTPS支持
CONFIG_PACKAGE_luci-theme-bootstrap=y # 默认主题
CONFIG_LUCI_LANG_zh_Hans=y       # 中文
CONFIG_LUCI_LANG_en=y            # 英文

# ===== 存储优化 =====
CONFIG_PACKAGE_kmod-usb-storage=y # USB存储支持
CONFIG_PACKAGE_kmod-usb-storage-uas=y # UAS支持
CONFIG_PACKAGE_kmod-fs-ext4=y    # EXT4支持（用于USB）
CONFIG_PACKAGE_kmod-fs-exfat=y   # exFAT支持
CONFIG_PACKAGE_kmod-fs-ntfs=y    # NTFS支持
CONFIG_PACKAGE_block-mount=y     # 块设备挂载
CONFIG_PACKAGE_automount=y       # 自动挂载

# ===== 基础工具包 =====
CONFIG_PACKAGE_bash=y            # Bash shell
CONFIG_PACKAGE_ca-bundle=y       # CA证书
CONFIG_PACKAGE_wget-ssl=y        # 安全版wget
CONFIG_PACKAGE_curl=y            # curl工具
CONFIG_PACKAGE_nano=y            # 文本编辑器
CONFIG_PACKAGE_htop=y            # 进程查看器

# ===== 内存优化 =====
CONFIG_PACKAGE_zram-swap=y       # ZRAM交换
CONFIG_PACKAGE_kmod-lib-lz4=y    # LZ4压缩
CONFIG_PACKAGE_kmod-lib-zstd=y   # Zstd压缩

# ===== 硬件特定优化 =====
CONFIG_PACKAGE_wifi-scripts=m    # WiFi脚本
CONFIG_KERNEL_XDP_SOCKETS=y      # 高性能网络
CONFIG_ZLIB_OPTIMIZE_SPEED=y     # zlib速度优化
CONFIG_ZSTD_OPTIMIZE_O3=y        # Zstd O3优化

# ===== 移除不必要的组件 =====
CONFIG_DEVEL=n                   # 关闭开发选项
CONFIG_TOOLCHAINOPTS=n
CONFIG_COREMARK_OPTIMIZE_O3=n    # 移除Coremark
CONFIG_COREMARK_ENABLE_MULTITHREADING=n
CONFIG_NODEJS_14=n               # 移除Node.js（太大）
CONFIG_XRAY_PROVIDE_V2RAY=n      # 移除代理工具

# ===== Docker支持调整 =====
# R7000闪存不足，建议使用USB存储运行Docker
# 仅保留基础cgroup支持
CONFIG_KERNEL_CGROUP_DEVICE=n
CONFIG_KERNEL_CGROUP_FREEZER=n
CONFIG_KERNEL_NET_CLS_CGROUP=n
CONFIG_KERNEL_CGROUP_NET_PRIO=n
CONFIG_KERNEL_MEMCG_SWAP_ENABLED=n
CONFIG_KERNEL_CFQ_GROUP_IOSCHED=n
CONFIG_KERNEL_CGROUP_PERF=y      # 基础性能监控
CONFIG_KERNEL_CGROUP_HUGETLB=y   # 大页支持
CONFIG_KERNEL_EXT4_FS_POSIX_ACL=y # ACL支持（USB存储需要）
CONFIG_KERNEL_EXT4_FS_SECURITY=y

# ===== 系统信息定制 =====
CONFIG_IMAGEOPT=y
CONFIG_VERSIONOPT=y
CONFIG_VERSION_MANUFACTURER="OpenWrt-R7000"
CONFIG_VERSION_FILENAMES=n
CONFIG_VERSION_CODE_FILENAMES=n

# ===== 已禁用驱动 =====
CONFIG_PACKAGE_kmod-pcie_mhi=n
CONFIG_PACKAGE_kmod-rtl8189es=n
