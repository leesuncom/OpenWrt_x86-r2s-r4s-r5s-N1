# ===== 系统核心设置 =====
CONFIG_GRUB_TIMEOUT="0"
CONFIG_GRUB_CONSOLE=n
CONFIG_TARGET_ROOTFS_EXT4FS=n
CONFIG_TARGET_ROOTFS_CPIOGZ=n
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_JFFS2=y  # 必须启用，用于可写覆盖层
CONFIG_TARGET_ROOTFS_PARTSIZE=  # 使用自动分配

# ===== 内核编译设置 =====
CONFIG_KERNEL_WERROR=n  # 禁用警告即错误
CONFIG_KERNEL_DEBUG=n   # 禁用调试符号
CONFIG_KERNEL_OPTIMIZE_FOR_SIZE=y  # 尺寸优化

# ===== 安全与验证 =====
CONFIG_SIGNED_PACKAGES=n
CONFIG_SIGNATURE_CHECK=n

# ===== 编译优化 =====
CONFIG_LUCI_CSSTIDY=n
CONFIG_CCACHE=y
CONFIG_BUILD_PATENTED=y
CONFIG_IB=y
CONFIG_IB_STANDALONE=y
CONFIG_JSON_OVERVIEW_IMAGE_INFO=y

# ===== 网络基础 =====
CONFIG_IPV6=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq_full_dhcp=y
CONFIG_PACKAGE_dnsmasq_full_ipset=y
CONFIG_PACKAGE_firewall=y
CONFIG_PACKAGE_miniupnpd-iptables=m

# ===== Web管理界面 =====
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_LUCI_LANG_en=y

# ===== 存储优化 =====
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-ntfs=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_automount=y

# ===== 基础工具包 =====
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_htop=y

# ===== 内存优化 =====
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_kmod-lib-lz4=y
CONFIG_PACKAGE_kmod-lib-zstd=y

# ===== 硬件特定优化 =====
CONFIG_PACKAGE_wifi-scripts=m
CONFIG_KERNEL_XDP_SOCKETS=y
CONFIG_ZLIB_OPTIMIZE_SPEED=y
CONFIG_ZSTD_OPTIMIZE_O3=y

# ===== 移除不必要的组件 =====
CONFIG_DEVEL=n
CONFIG_TOOLCHAINOPTS=n
CONFIG_COREMARK_OPTIMIZE_O3=n
CONFIG_COREMARK_ENABLE_MULTITHREADING=n
CONFIG_NODEJS_14=n
CONFIG_XRAY_PROVIDE_V2RAY=n

# ===== Docker支持调整 =====
CONFIG_KERNEL_CGROUP_PERF=y
CONFIG_KERNEL_CGROUP_HUGETLB=y
CONFIG_KERNEL_EXT4_FS_POSIX_ACL=y
CONFIG_KERNEL_EXT4_FS_SECURITY=y

# 禁用不必要的cgroup特性
CONFIG_KERNEL_CGROUP_DEVICE=n
CONFIG_KERNEL_CGROUP_FREEZER=n
CONFIG_KERNEL_NET_CLS_CGROUP=n
CONFIG_KERNEL_CGROUP_NET_PRIO=n
CONFIG_KERNEL_MEMCG_SWAP_ENABLED=n
CONFIG_KERNEL_CFQ_GROUP_IOSCHED=n

# ===== 系统信息定制 =====
CONFIG_IMAGEOPT=y
CONFIG_VERSIONOPT=y
CONFIG_VERSION_MANUFACTURER="OpenWrt-R7000"
CONFIG_VERSION_FILENAMES=n
CONFIG_VERSION_CODE_FILENAMES=n

# ===== 已禁用驱动 =====
CONFIG_PACKAGE_kmod-pcie_mhi=n
CONFIG_PACKAGE_kmod-rtl8189es=n

# ===== 内核补丁应用 =====
# 添加内核补丁解决编译错误
CONFIG_TARGET_PATCH_DIR="patches-6.6"
